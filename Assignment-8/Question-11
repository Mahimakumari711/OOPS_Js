import java.util.Scanner; 
class SharedMin { 
  int globalMin;  
  SharedMin(int initialValue) { 
    this.globalMin = initialValue; 
  } 
} 
class MinFinderThread extends Thread { 
  private int[] arr; 
  private int start, end; 
  private SharedMin shared;  
  MinFinderThread(int[] arr, int start, int end, SharedMin shared) {
    this.arr = arr; 
    this.start = start; 
    this.end = end; 
    this.shared = shared; 
  } 
  public void run() { 
    int localMin = arr[start]; 
    for (int i = start + 1; i <= end; i++) { 
      if (arr[i] < localMin) 
        localMin = arr[i]; 
    } 
    synchronized (shared) { 
      if (localMin < shared.globalMin) { 
        shared.globalMin = localMin; 
      } 
      System.out.println(Thread.currentThread().getName() + " found local min = " + localMin + " | Updated global min = " + shared.globalMin); 
    } 
  } 
} 
class Driver { 
  public static void main(String[] args) { 
    Scanner sc = new Scanner(System.in); 
    System.out.print("Enter number of elements in array: "); 
    int n = sc.nextInt(); 
    int[] arr = new int[n]; 
    System.out.println("Enter array elements:"); 
    for (int i = 0; i < n; i++) { 
      arr[i] = sc.nextInt(); 
    } 
    System.out.print("Enter number of threads: ");
    int m = sc.nextInt(); 
    SharedMin shared = new SharedMin(arr[0]); 
    int blockSize = n / m; 
    int remainder = n % m; 
    int start = 0; 
    MinFinderThread[] threads = new MinFinderThread[m]; 
    for (int i = 0; i < m; i++) { 
      int end = start + blockSize - 1; 
      if (i == m - 1) {   
        end += remainder; 
      } 
      threads[i] = new MinFinderThread(arr, start, end, shared); 
      threads[i].setName("Thread-" + (i + 1)); 
      threads[i].start(); 
      start = end + 1; 
    } 
    for (int i = 0; i < m; i++) { 
      try { 
        threads[i].join(); 
      } 
      catch (InterruptedException e) { 
        e.printStackTrace(); 
      } 
    } 
    System.out.println("\nFinal Global Minimum = " + shared.globalMin); 
  } 
} 
