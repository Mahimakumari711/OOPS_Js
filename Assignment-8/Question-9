import java.util.Scanner; 
class ArrayData { 
  int[] arr1, arr2, result; 
  ArrayData(int[] arr1, int[] arr2) { 
    this.arr1 = arr1; 
    this.arr2 = arr2; 
    this.result = new int[arr1.length]; 
  } 
} 
class OddIndexThread extends Thread { 
  private ArrayData data; 
  OddIndexThread(ArrayData data) { 
    this.data = data; 
  } 
  public void run() { 
    for (int i = 1; i < data.arr1.length; i += 2) { 
      data.result[i] = data.arr1[i] * data.arr2[i]; 
      System.out.println("OddIndexThread: result[" + i + "] = " + data.result[i]); 
      try { 
        Thread.sleep(50);
      } 
      catch (InterruptedException e) { 
        e.printStackTrace(); 
      } 
    } 
    System.out.println("OddIndexThread completed.\n"); 
  } 
} 
class EvenIndexThread extends Thread { 
  private ArrayData data; 
  EvenIndexThread(ArrayData data) { 
    this.data = data; 
  } 
  public void run() { 
    for (int i = 0; i < data.arr1.length; i += 2) { 
      data.result[i] = data.arr1[i] * data.arr2[i]; 
      System.out.println("EvenIndexThread: result[" + i + "] = " + data.result[i]); 
      try { 
        Thread.sleep(50); 
      } 
      catch (InterruptedException e) { 
        e.printStackTrace(); 
      } 
    } 
    System.out.println("EvenIndexThread completed.\n"); 
  } 
} 
public class Driver { 
  public static void main(String[] args) { 
    Scanner sc = new Scanner(System.in); 
    System.out.print("Enter the size of the arrays: "); 
    int size = sc.nextInt(); 
    int[] arr1 = new int[size]; 
    int[] arr2 = new int[size];
    System.out.println("Enter elements of first array:"); 
    for (int i = 0; i < size; i++) { 
      arr1[i] = sc.nextInt(); 
    } 
    System.out.println("Enter elements of second array:"); 
    for (int i = 0; i < size; i++) { 
      arr2[i] = sc.nextInt(); 
    } 
    ArrayData data = new ArrayData(arr1, arr2); 
    OddIndexThread oddThread = new OddIndexThread(data); 
    EvenIndexThread evenThread = new EvenIndexThread(data); 
    oddThread.start(); 
    evenThread.start(); 
    try { 
      oddThread.join(); 
      evenThread.join(); 
    } 
    catch (InterruptedException e) { 
      e.printStackTrace(); 
    } 
    System.out.println("Main Thread: Final Result Array:"); 
    for (int i = 0; i < size; i++) { 
      System.out.print(data.result[i] + " "); 
    } 
    System.out.println("\nMain Thread completed."); 
  } 
}
