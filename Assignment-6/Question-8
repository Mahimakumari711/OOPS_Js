File 1 : Square  

package org.shapes; 
public class Square { 
  private double side; 
  public Square(double side) { 
    this.side = side; 
  } 
  public double area() { 
    return side * side; 
  } 
  public double perimeter() { 
    return 4 * side; 
  } 
}

File 2 : Circle  

package org.shapes; 
public class Circle { private double radius; 
  public Circle(double radius) { 
    this.radius = radius; 
  } 
  public double area() { 
      return Math.PI * radius * radius; 
  } 
  public double perimeter() { 
      return 2 * Math.PI * radius; 
  } 
}

File 3 : Triangle  

package org.shapes; 
public class Triangle { private double a, b, c; 
  public Triangle(double a, double b, double c) { 
      this.a = a; 
      this.b = b; 
      this.c = c; 
  } 
 
  public double perimeter() { 
      return a + b + c; 
  }
  public double area() { 
      double s = perimeter() / 2; 
      return Math.sqrt(s * (s - a) * (s - b) * (s - c)); 
  } 
} 

