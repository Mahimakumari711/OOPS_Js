File 1 : MyMath 

package btech.arithmetic; 
public class MyMath { 
  public int add(int a, int b) { 
    return a + b;
  } 
  public int sub(int a, int b) { 
    return a - b; 
  } 
  public int mul(int a, int b) { 
    return a * b; 
  } 
  public double div(int a, int b) { 
    if (b == 0) { 
      System.out.println("Error: Division by zero!"); 
      return 0; 
    } 
    return (double) a / b; 
  } 
  public int mod(int a, int b) { 
    return a % b; 
  } 
}

